    {
      "id": "Ckz2Wh2VkNAqLQjdlrSxz",
      "type": "text",
      "x": 2458.9999084472656,
      "y": 358.2781524658203,
      "width": 452.8997802734375,
      "height": 150,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
